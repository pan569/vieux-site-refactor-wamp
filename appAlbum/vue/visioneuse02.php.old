						<text x="95" y="80" class="bulle"  transform="translate(<?= $png['translate'] ;?>) scale(<?= $png['scale'] ;?>)"  ><?= $png['texte'] ?></text>
					</g>
					<?php endif ?>
					
					<g style="opacity: 0.5;" />				
