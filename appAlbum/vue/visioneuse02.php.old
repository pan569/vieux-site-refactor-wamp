<?php



use appAlbum\modele\iptc;

//debug($model,"liste des fichiers JPEG");



$width=1000;// $model['width'];
$height=600;

//$nomImage= "lili.jpg";
$fontSize = "65px";
$png = null;

if($nomImage === null)
{
    
    $texte = "pas d'image selectionée";
    $hrefImage="/appAlbum/vue/resource/img/09.jpg";
    $chemin = "C:\\wamp64\\www\\site01\\appAlbum\\vue\\resources\\img\\09.jpg";
    $scaleImage = 1;
    $xImage = ($height - 600)/2;
}
else 
{
    $chemin = "C:\\wamp64\\www\\site01\\appAlbum\\vue\\resources\\img\\X\\".$nomImage;
    
    $exif01 = exif_read_data($chemin,'FILE',true);
    $iptc = new \appAlbum\modele\iptc($chemin);
    
    //debug($iptc->iptc,"itcp");
    //debug($iptc['Description'],"itcp_description");
    //debug($iptc['Instructions'],"itcp_Instructions");
    
    
    $texte = $iptc['Description'];
    $hrefImage="/appAlbum/vue/resources/img/X/{$nomImage}";
    
    $scaleImage = $width/$exif01['COMPUTED']['Width'];
    
    $height=              $exif01['COMPUTED']['Height']*$scaleImage;
    $xImage = ($width  - ($exif01['COMPUTED']['Width']*$scaleImage)) /2;
    
    
    if($iptc->offsetExists('Instructions'))
    {
        $png = json_decode($iptc['Instructions'], true);
    }
    
    //debug($png,"png");
    
    
    
}



