

function coordonnees(pos) 
{
    let crd = pos.coords;
  
    let latitude = crd.latitude;
    let longitude = crd.longitude;
    
    document.getElementById('pLatitude').innerHTML= 'Latitude : ' + latitude.toFixed(2);
    document.getElementById('pLongitude').innerHTML= 'Longitude : ' + longitude.toFixed(2);
}

navigator.geolocation.getCurrentPosition(coordonnees);

