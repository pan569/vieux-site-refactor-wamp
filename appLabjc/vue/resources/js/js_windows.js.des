document.getElementById('phlenght').innerHTML =  history.length;
let bhgo = document.getElementById('bhgo');
let bhback = document.getElementById('bhback');
let bhforward = document.getElementById('bhforward');
bhgo.addEventListener('click', history_go);
bhback.addEventListener('click', history_back);
bhforward.addEventListener('click', history_forward);

function history_go()
{
	history.go(-2)
}
function history_back()
{
	history.back()
}
function history_forward()
{
	history.forward()
}

console.log(window.history);


