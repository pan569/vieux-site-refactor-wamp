document.getElementById('pcookieEnabled').innerHTML = navigator.cookieEnabled;
document.getElementById('pplatform').innerHTML = navigator.platform;
document.getElementById('pappName').innerHTML = navigator.appName;
document.getElementById('pappCodeName').innerHTML = navigator.appCodeName;
document.getElementById('pappVersion').innerHTML = navigator.appVersion;
document.getElementById('puserAgent').innerHTML = navigator.userAgent;                                  
document.getElementById('pgeolocation').innerHTML = navigator.geolocation;

