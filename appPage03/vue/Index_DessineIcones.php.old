<?php

use appPage03\modele\DonneesTrigo;


//## ELEMENTS POUR DESSINER LES ICONES ##\\
$nbrIcon = 6;
$widthIcon = 100;
$bordure= ($model['width'] - ($nbrIcon*$widthIcon) ) / (2*$nbrIcon);
$pas= $widthIcon + 2*$bordure;

//## ELEMENTS POUR DESSINER LES BRANCHES ##\\
$rayon = 20;
$xDebut = $model['width']/2;
$yDebut = $model['height'] ;
$xFin = $model['width']/4;
$yFin = $yDebut;


$angle=180/($nbrIcon-1);


