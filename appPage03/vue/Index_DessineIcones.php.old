?>

<h1> jouer avec les svg </h1>

<svg width="<?= $model['width'];?>" height="<?= $model['height'];?>" xml:lang="fr" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
	<title>Test</title>
	<desc>travail sur les fichiers SVG</desc>
	<style type="text/css">
    <![CDATA[
       
   .forme
   {
        fill:white;
        stroke:black;
        stroke-width:1px;
   }
   
   ]]>
   </style>
   
   <rect x="0" y="0" width="<?= $model['width'];?>" height="<?= $model['height'];?>" class="forme" />
   
	<defs>	
		<g id="point" transform="translate(-5,-5)">
			<image xlink:href="/appPage03/vue/point.svg"  />		
		</g>
		<g id="icon" width="<?= $pas ;?>" height="150">					
			<rect width="<?= $widthIcon ;?>" height="<?= $widthIcon ;?>" x="<?= $bordure ;?>" class="forme" />
			<image xlink:href="/appPage03/vue/point.svg" x="<?= $bordure + $widthIcon/2 ;?>" y="<?= $widthIcon/2 ;?>" transform="translate(-5,-5)" />
		</g>
	</defs>
	
	<!-- dessin des icons -->
	<?php for ($i = 0 ; $i <= $pas * $nbrIcon ; $i=$i+$pas): ?>
		<use xlink:href="#icon" transform="translate(<?= $i ;?>,<?= 25 ;?>)"/>
	<?php endfor;?>
	
	<!-- dessin des branches -->
	<?php for ($i = 0; $i <= 180; $i=$i+$angle): ?>
	<?php  $dt = new DonneesTrigo($i, $xFin, 0);?>
    	<line x1="<?= $xDebut ;?>" y1="<?= $yDebut ;?>" x2="<?= $xFin ;?>"  y2="<?=$yFin;?>" transform="rotate(<?= $dt['angleA'] ;?>, <?= $xDebut ;?>, <?= $yDebut ;?>)"  class="forme" />
		<line x1="<?= $xDebut + $dt['x'] ;?>" y1="<?= $yDebut - $dt['y'] ;?>" x2="<?= $xDebut + $dt['x'] ;?>"  y2="<?= $yDebut -  ($model['width']/3 -0 )  ;?>"  class="forme" />
	<?php endfor;?>
		
</svg>	

